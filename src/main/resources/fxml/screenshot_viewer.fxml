<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.androidnexus.ui.controller.ScreenshotController"
      styleClass="background-pane">
    
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- Header -->
    <VBox spacing="5">
        <Label text="Screen Control &amp; Screenshot" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: -text-primary;"/>
        <Label text="Capture active screens, mirror display feeds, and control media" style="-fx-text-fill: -text-secondary;"/>
    </VBox>

    <!-- Split View: Preview vs Control Buttons -->
    <SplitPane dividerPositions="0.65" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
        <!-- Left Panel: Large Image View -->
        <VBox alignment="CENTER" spacing="10" style="-fx-background-color: -bg-secondary; -fx-padding: 20; -fx-background-radius: 8px; -fx-border-color: -border-color; -fx-border-radius: 8px;">
            <StackPane VBox.vgrow="ALWAYS" style="-fx-background-color: #000000; -fx-background-radius: 4px;">
                <ImageView fx:id="imgPreview" fitWidth="400" fitHeight="600" preserveRatio="true"/>
                <Label fx:id="lblNoPreview" text="No screenshot captured yet" style="-fx-text-fill: -text-secondary; -fx-font-size: 16px;"/>
            </StackPane>
            <HBox spacing="10" alignment="CENTER">
                <Label text="Local Save Directory:" style="-fx-text-fill: -text-secondary;"/>
                <Label fx:id="lblSavePath" text="N/A" style="-fx-text-fill: -text-primary; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>

        <!-- Right Panel: Vertical Control Columns -->
        <VBox spacing="20" style="-fx-padding: 0 10 0 20;">
            <!-- Actions Section -->
            <VBox spacing="10">
                <Label text="Quick Actions" style="-fx-font-weight: bold; -fx-text-fill: -text-primary; -fx-font-size: 14px;"/>
                <Separator/>
                <HBox spacing="10">
                    <Button fx:id="btnCapture" text="Take Screenshot" onAction="#handleCapture" styleClass="nav-button-active" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <Button fx:id="btnOpenFolder" text="Open Folder" onAction="#handleOpenFolder" styleClass="nav-button-active"/>
                </HBox>
                <Button fx:id="btnMirror" text="Launch Live Mirroring" onAction="#handleMirror" styleClass="nav-button-active" maxWidth="Infinity"/>
            </VBox>

            <!-- Media Section -->
            <VBox spacing="10">
                <Label text="Hardware &amp; Media Controls" style="-fx-font-weight: bold; -fx-text-fill: -text-primary; -fx-font-size: 14px;"/>
                <Separator/>
                <Button fx:id="btnPower" text="Power Button (Lock/Unlock)" onAction="#handlePower" styleClass="nav-button-active" maxWidth="Infinity"/>
                <Button fx:id="btnVolumeUp" text="Volume Up" onAction="#handleVolumeUp" styleClass="nav-button-active" maxWidth="Infinity"/>
                <Button fx:id="btnVolumeDown" text="Volume Down" onAction="#handleVolumeDown" styleClass="nav-button-active" maxWidth="Infinity"/>
                <Button fx:id="btnMute" text="Mute Toggle" onAction="#handleMute" styleClass="nav-button-active" maxWidth="Infinity"/>
            </VBox>

            <Region VBox.hgrow="ALWAYS"/>

            <!-- Status Indicator Overlay -->
            <HBox spacing="10" alignment="CENTER" fx:id="statusOverlay" visible="false">
                <ProgressIndicator prefWidth="16" prefHeight="16"/>
                <Label fx:id="lblStatus" text="Capturing screen..." style="-fx-text-fill: -accent-color;"/>
            </HBox>
        </VBox>
    </SplitPane>

</VBox>
