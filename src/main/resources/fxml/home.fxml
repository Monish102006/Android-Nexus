<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true" styleClass="background-pane"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.androidnexus.ui.controller.HomeController">
    
    <VBox spacing="20">
        <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
        </padding>

        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="15">
            <VBox HBox.hgrow="ALWAYS">
                <Label text="Welcome Home" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: -text-primary;"/>
                <Label text="Live overview of your connected Android device status and properties" style="-fx-text-fill: -text-secondary;"/>
            </VBox>
            <Button fx:id="btnRefresh" text="Refresh Info" styleClass="nav-button-active" onAction="#loadDeviceData"/>
        </HBox>

        <!-- Loading Indicator Stack -->
        <StackPane fx:id="loadingOverlay" visible="false">
            <ProgressIndicator prefWidth="50" prefHeight="50"/>
        </StackPane>

        <GridPane hgap="20" vgap="20" fx:id="contentGrid">
            <columnConstraints>
                <ColumnConstraints percentWidth="50"/>
                <ColumnConstraints percentWidth="50"/>
            </columnConstraints>

            <!-- Card 1: System Properties -->
            <VBox spacing="15" GridPane.columnIndex="0" GridPane.rowIndex="0" 
                  style="-fx-background-color: -bg-secondary; -fx-padding: 20; -fx-background-radius: 8px; -fx-border-color: -border-color; -fx-border-radius: 8px;">
                <Label text="System Properties" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: -text-primary;"/>
                <Separator/>
                <GridPane hgap="10" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints minWidth="120" prefWidth="150"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>

                    <Label text="Manufacturer:" style="-fx-text-fill: -text-secondary;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <Label fx:id="lblManufacturer" text="Loading..." style="-fx-text-fill: -text-primary; -fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                    <Label text="Model:" style="-fx-text-fill: -text-secondary;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <Label fx:id="lblModel" text="Loading..." style="-fx-text-fill: -text-primary; -fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                    <Label text="Android Version:" style="-fx-text-fill: -text-secondary;" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <Label fx:id="lblAndroidVersion" text="Loading..." style="-fx-text-fill: -text-primary;" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                    <Label text="API Level (SDK):" style="-fx-text-fill: -text-secondary;" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <Label fx:id="lblApiLevel" text="Loading..." style="-fx-text-fill: -text-primary;" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                    <Label text="Screen Resolution:" style="-fx-text-fill: -text-secondary;" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                    <Label fx:id="lblScreenResolution" text="Loading..." style="-fx-text-fill: -text-primary;" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                    <Label text="Serial Number:" style="-fx-text-fill: -text-secondary;" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                    <Label fx:id="lblSerialNumber" text="Loading..." style="-fx-text-fill: -text-primary;" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                </GridPane>
            </VBox>

            <!-- Card 2: Battery Status -->
            <VBox spacing="15" GridPane.columnIndex="1" GridPane.rowIndex="0" 
                  style="-fx-background-color: -bg-secondary; -fx-padding: 20; -fx-background-radius: 8px; -fx-border-color: -border-color; -fx-border-radius: 8px;">
                <Label text="Battery Status" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: -text-primary;"/>
                <Separator/>
                <VBox spacing="10" alignment="CENTER_LEFT">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="Battery Level:" style="-fx-text-fill: -text-secondary;"/>
                        <Label fx:id="lblBatteryPercent" text="--%" style="-fx-font-weight: bold; -fx-text-fill: -text-primary;"/>
                    </HBox>
                    <ProgressBar fx:id="pbBattery" progress="0.0" maxWidth="Infinity" prefHeight="15"/>
                    
                    <GridPane hgap="10" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints minWidth="120"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>
                        <!-- Other metrics are fetched in battery dumpsys parsing if present -->
                        <Label text="Power Source:" style="-fx-text-fill: -text-secondary;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <Label fx:id="lblPowerSource" text="Battery" style="-fx-text-fill: -text-primary;" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                        <Label text="Health:" style="-fx-text-fill: -text-secondary;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <Label fx:id="lblBatteryHealth" text="Good" style="-fx-text-fill: -text-primary;" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    </GridPane>
                </VBox>
            </VBox>

            <!-- Card 3: Storage Meter -->
            <VBox spacing="15" GridPane.columnIndex="0" GridPane.rowIndex="1" 
                  style="-fx-background-color: -bg-secondary; -fx-padding: 20; -fx-background-radius: 8px; -fx-border-color: -border-color; -fx-border-radius: 8px;">
                <Label text="Device Storage" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: -text-primary;"/>
                <Separator/>
                <VBox spacing="10" alignment="CENTER_LEFT">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="Storage Used:" style="-fx-text-fill: -text-secondary;"/>
                        <Label fx:id="lblStorageUsed" text="Loading..." style="-fx-font-weight: bold; -fx-text-fill: -text-primary;"/>
                    </HBox>
                    <ProgressBar fx:id="pbStorage" progress="0.0" maxWidth="Infinity" prefHeight="15"/>
                    <HBox alignment="CENTER" spacing="10">
                        <Label text="Total Space:" style="-fx-text-fill: -text-secondary;"/>
                        <Label fx:id="lblStorageTotal" text="-- GB" style="-fx-text-fill: -text-primary;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="Free Space:" style="-fx-text-fill: -text-secondary;"/>
                        <Label fx:id="lblStorageFree" text="-- GB" style="-fx-text-fill: -text-primary;"/>
                    </HBox>
                </VBox>
            </VBox>

            <!-- Card 4: Device Capabilities -->
            <VBox spacing="15" GridPane.columnIndex="1" GridPane.rowIndex="1" 
                  style="-fx-background-color: -bg-secondary; -fx-padding: 20; -fx-background-radius: 8px; -fx-border-color: -border-color; -fx-border-radius: 8px;">
                <Label text="Device Capabilities" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: -text-primary;"/>
                <Separator/>
                <FlowPane hgap="10" vgap="10">
                    <Label fx:id="badgeNotifs" text="Notification Access" style="-fx-padding: 6 12 6 12; -fx-background-radius: 4px; -fx-font-weight: bold;"/>
                    <Label fx:id="badgeRecording" text="Screen Recording" style="-fx-padding: 6 12 6 12; -fx-background-radius: 4px; -fx-font-weight: bold;"/>
                    <Label fx:id="badgeFlashlight" text="Camera Flashlight" style="-fx-padding: 6 12 6 12; -fx-background-radius: 4px; -fx-font-weight: bold;"/>
                    <Label fx:id="badgeMedia" text="Media Control" style="-fx-padding: 6 12 6 12; -fx-background-radius: 4px; -fx-font-weight: bold;"/>
                </FlowPane>
            </VBox>

        </GridPane>
    </VBox>
</ScrollPane>
